{
  "name": "lj-s-tutoring",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.100.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cpy-cli": "^5.0.0",
    "date-fns": "^4.4.0",
    "dotenv": "^16.4.5",
    "gsap": "^3.15.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.8.1",
    "rimraf": "^5.0.5",
    "sonner": "^2.0.7",
    "split-type": "^0.3.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.0",
    "html-validate": "^9.5.3"
  },
  "scripts": {
    "clean": "rimraf dist",
    "dev:react": "vite --config vite.app.config.ts --host 0.0.0.0 --port 5173",
    "build:react": "vite build --config vite.app.config.ts",
    "build:static": "node scripts/build-static.js",
    "build:css": "tailwindcss -c tailwind.config.js -i ./assets/tailwind-input.css -o ./dist/assets/tailwind-input.css --minify",
    "inject:config": "node scripts/inject-config.js",
    "verify:static-assets": "node scripts/verify-static-assets.js",
    "build:api": "npm ci --prefix lms-api && npm run build --prefix lms-api",
    "build": "npm run build:react && npm run build:static && npm run build:css && npm run inject:config && npm run verify:static-assets",
    "serve": "node scripts/serve-static.js",
    "start:static": "npm run serve",
    "start:api": "npm run start --prefix lms-api",
    "start": "npm-run-all --parallel start:static start:api",
    "dev:static": "npm run build:static && npm run build:css && npm run inject:config && npm run serve",
    "dev:api": "npm run dev --prefix lms-api",
    "dev:full": "npm-run-all --parallel dev:static dev:api",
    "dev": "npm run dev:full",
    "migrate": "npm run migrate --prefix lms-api",
    "db:create:local": "npm run db:create:local --prefix lms-api",
    "test:frontend:unit": "node --test tests/frontend",
    "verify:supabase:roles": "node scripts/verify-supabase-dashboard-access.cjs",
    "test:release:evidence": "node --test tests/release-evidence.test.cjs",
    "test:api": "npm run test --prefix lms-api",
    "test:e2e:api": "npm run test:e2e --prefix lms-api",
    "test:e2e:web": "playwright test",
    "test:e2e:web:headed": "playwright test --headed",
    "test:unit": "npm run test:frontend:unit",
    "test:all": "npm-run-all test:unit test:api test:e2e:api",
    "test": "npm run test:all",
    "typecheck:react": "tsc --noEmit -p tsconfig.app.json",
    "typecheck": "npm run typecheck:react",
    "perf:budget": "node scripts/check-frontend-performance-budget.cjs",
    "validate:monitoring": "node scripts/validate-monitoring-assets.js",
    "lint:js": "eslint \"assets/**/*.js\" \"scripts/**/*.js\" --max-warnings=0",
    "lint:html": "html-validate \"*.html\" \"legacy/static/**/*.html\"",
    "lint": "npm-run-all --parallel lint:js lint:html",
    "prepare": "husky || echo husky-not-installed"
  }
}
